{
	"version": "2.2.0-beta.0",
	"name": "@apifuse/provider-sdk",
	"private": false,
	"type": "module",
	"description": "APIFuse Provider SDK — Build providers with zero architectural constraints",
	"license": "MIT",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"src",
		"!src/__tests__",
		"!src/__tests__/**",
		"!src/**/*.test.ts",
		"!src/index.test.ts",
		"bin",
		"README.md",
		"AUTHORING.md",
		"CHANGELOG.md",
		"SUBMISSION.md"
	],
	"keywords": [
		"apifuse",
		"provider",
		"sdk",
		"api",
		"zod",
		"hono"
	],
	"bin": {
		"apifuse": "./bin/apifuse.ts"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./provider": {
			"types": "./dist/provider.d.ts",
			"import": "./dist/provider.js",
			"default": "./dist/provider.js"
		},
		"./contract": {
			"types": "./dist/contract.d.ts",
			"import": "./dist/contract.js",
			"default": "./dist/contract.js"
		},
		"./auth-turn": {
			"types": "./dist/auth-turn/index.d.ts",
			"import": "./dist/auth-turn/index.js",
			"default": "./dist/auth-turn/index.js"
		},
		"./auth-turn/auth-turn.v1.schema.json": "./dist/auth-turn/auth-turn.v1.schema.json",
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js",
			"default": "./dist/server/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js",
			"default": "./dist/testing/index.js"
		},
		"./create": {
			"types": "./dist/cli/create.d.ts",
			"import": "./dist/cli/create.js",
			"default": "./dist/cli/create.js"
		}
	},
	"scripts": {
		"lint": "biome lint .",
		"lint:fix": "biome lint --write",
		"format": "biome format --write",
		"type-check": "tsgo --noEmit",
		"test": "bun test",
		"check": "bun run lint && bun run type-check && bun run build",
		"pack:check": "bun run build && bun bin/apifuse-pack-check.ts",
		"pack:smoke": "bun run build && bun bin/apifuse-pack-smoke.ts",
		"release:guard": "bun scripts/guard-release-pr.ts",
		"format:check": "biome format .",
		"build": "tsgo -p tsconfig.build.json && rm -rf dist/cli/templates && cp -R src/cli/templates dist/cli/templates && rm -rf dist/auth-turn/fixtures && cp -R src/auth-turn/fixtures dist/auth-turn/fixtures && cp src/auth-turn/auth-turn.v1.schema.json dist/auth-turn/auth-turn.v1.schema.json"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/bun": "latest",
		"@types/node": "^25.9.3",
		"@typescript/native-preview": "7.0.0-dev.20260419.1"
	},
	"dependencies": {
		"@clack/prompts": "^1.5.1",
		"@types/ms": "^2.1.0",
		"acorn": "^8.17.0",
		"ajv": "^8.17",
		"hono": "^4.12.25",
		"impit": "0.14.1",
		"ioredis": "^5.11.1",
		"ms": "^2.1.3",
		"playwright": "^1.55.1",
		"playwright-extra": "^4.3.6",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"re2-wasm": "^1.0",
		"safe-regex": "^2.1",
		"zod": "^4.4.3"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/APIFuseHQ/provider-sdk.git"
	},
	"bugs": {
		"url": "https://github.com/APIFuseHQ/provider-sdk/issues"
	},
	"homepage": "https://github.com/APIFuseHQ/provider-sdk#readme"
}
