{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"emitDeclarationOnly": false,
		"allowImportingTsExtensions": false,
		"paths": {}
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"src/__tests__",
		"**/*.test.ts",
		"**/*.spec.ts"
	]
}
